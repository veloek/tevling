<div class="icon-badge-container">
    <i class="bi bi-bell-fill me-2 icon-badge-icon me-2"></i>@Text
    @if (NotificationCount is > 0 and < 10)
    {
        <Badge Text="@NotificationCount.ToString()"></Badge>
    }
    @if (NotificationCount >=  10)
    {
        <Badge Text="+"></Badge>
    }
</div>
