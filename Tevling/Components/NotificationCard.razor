@inject NotificationTranslator NotificationTranslator
@if (Notification is not null)
{
    <div class="notification-card px-3 py-2 d-flex flex-row flex-wrap @(Notification.Read is null ? "notification-unread" : "notification-read")">
        <div class="notification-card-content pb-1 d-flex flex-column">
            <div class="notification-card-header mb-2 d-flex flex-row align-items-center flex-wrap-reverse row-gap-1">
                <span class="notification-time">@NotificationTime</span>
            </div>

            @if (Notification is ISystemNotification)
            {
            <div class="d-flex align-items-center flex-row column-gap-2 athlete-name-container me-1">
                <span class="athlete-name">@(NotificationTranslator.Translate(Notification))</span>
            </div>
            }
            else
            {
            <div class="d-flex align-items-center flex-row column-gap-2 athlete-name-container me-1">
                <Avatar AthleteId="@Notification.CreatedBy?.Id" Size="40" />
                <span class="notification-name">@Notification.CreatedBy?.Name</span>
                <span class="athlete-name"> - @(NotificationTranslator.Translate(Notification))</span>
            </div>
            }
        </div>
    </div>
}
